{
  "name": "nightingale",
  "version": "0.1.0",
  "description": "AI receptionist for UK GP & dental practices — books, cancels, reschedules and confirms appointments over voice, and safely escalates clinical requests to humans.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Ethan Kennedy",
  "repository": {
    "type": "git",
    "url": "https://github.com/ejkennedy/nightingale.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:migrate:local": "wrangler d1 migrations apply nightingale --local",
    "db:migrate:remote": "wrangler d1 migrations apply nightingale --remote",
    "db:seed:local": "wrangler d1 execute nightingale --local --file=./src/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute nightingale --remote --file=./src/db/seed.sql",
    "db:reset:local": "bun run db:migrate:local && bun run db:seed:local"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9",
    "wrangler": "^3.114.0"
  }
}
